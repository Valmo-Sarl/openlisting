{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Valmo-Sarl/openlisting/schema/openlisting-batch.schema.json",
  "title": "OpenListing batch",
  "type": "object",
  "required": ["kind", "openlistingVersion", "items"],
  "properties": {
    "kind": { "const": "openlisting.batch" },
    "openlistingVersion": { "type": "string", "pattern": "^0\\.1\\.[0-9]+$" },
    "source": { "type": "string", "maxLength": 80 },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/definitions/classifiedAd" }
    }
  },
  "definitions": {
    "classifiedAd": {
      "type": "object",
      "required": ["id", "type", "title", "description", "price"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 190 },
        "type": { "const": "classified_ad" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "minLength": 1 },
        "price": {
          "type": "object",
          "required": ["amount", "currency"],
          "properties": {
            "amount": { "type": "number", "minimum": 0 },
            "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
          }
        },
        "condition": {
          "type": "string",
          "enum": ["unknown", "new", "like_new", "very_good", "good", "used", "for_parts"]
        },
        "location": {
          "type": "object",
          "properties": {
            "postalCode": { "type": "string" },
            "city": { "type": "string" },
            "region": { "type": "string" },
            "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
          }
        },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "position": { "type": "integer", "minimum": 0 },
              "uri": { "type": "string" }
            }
          }
        },
        "destinationData": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        }
      }
    }
  }
}
